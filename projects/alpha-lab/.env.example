# AlphaLab Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ── OpenAI (required if using provider: "openai") ──
OPENAI_API_KEY=your-openai-api-key

# ── Anthropic (required if using provider: "anthropic") ──
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Python for experiments ──
# Full path to Python with torch/numpy/pandas installed.
# Used by Phase 3 to run GPU experiment subprocesses.
# If unset, falls back to sys.executable.
# ALPHALAB_PYTHON=/path/to/your/python
